<%- include('partials/head.ejs') %>
<link rel="stylesheet" href="../styles/button-hover.css">
<script src='../scripts/manager.js'></script>
<script src='../scripts/post_sender.js'></script>
<script src='../scripts/elements_parser.js'></script>
<script src='../scripts/request_handler.js'></script>
<script src='../scripts/popup_manager.js'></script>
<%- include('partials/navbar.ejs') %>
<body class='container-fluid'>
    <div class="row justify-content-left button-row">
        <div class="col-2 align-self-center">
            <a href="../e390cd59e40e7dc601c9a8c1cde91417e6cc18bd950f8f061fff24b1b23b81b6/manager" class="btn btn-dark py-2 btn-lg first-button-back" role="button" aria-pressed="true">Back</a>
            <a class="btn btn-dark py-2 btn-lg second-button-back" style='display:none;' role="button" aria-pressed="true" onclick="add_hide();remove_hide();">Back</a>

        </div>
    </div>
    <div class="row justify-content-evenly buttons-class" style='display:flex'>
        <div class="d-flex align-content-center justify-content-center m-4 col-10 col-md-4 border border-4 border-dark rounded text-center align-items-center p-5 hover-effect" onclick="add_show()">
            <p class='fs-1'>Add member</p>
        </div>
        <div class="d-flex align-content-center justify-content-center m-4 col-10 col-md-4 border border-4 border-dark rounded text-center align-items-center p-5 hover-effect" onclick="remove_show()">
            <p class='fs-1'>Remove member</p>
        </div>
    </div>
    <div class="my-4 add" style='display:none'>
        <div class="row justify-content-center">
            <form class="col-11 col-md-9 form-add" action='add-manager' method='post'>
                <input type='hidden' value='members'>
                <div class="form-group my-4">
                    <label for="Name">Member name</label>
                    <input type="text" class="form-control" id="Name" aria-describedby="Name" placeholder="Enter Name">
                </div>
                <div class="form-group my-4">
                    <label for="Nickname">Nickname</label>
                    <input type="text" class="form-control" id="Nickname" aria-describedby="Nickname" placeholder="Enter Nickname">
                </div>
                <div class="form-group my-4">
                    <label for="Year">Join year</label>
                    <input type="text" class="form-control" id="Year" aria-describedby="Year" placeholder="2019, 2020, ....">
                </div>
                <div class="form-group my-4">
                    <label for="Link">Website / profile link</label>
                    <input type="text" class="form-control" id="Link" aria-describedby="Link" placeholder="Enter personal profile, JUST ONE LINK (github, LinkedIn, ..)">
                </div>
                <div class="form-group my-4">
                    <label for="Description">Description</label>
                    <textarea type="text" class="form-control" id="Description" placeholder="Categories: ...&#10;University ..."></textarea>
                </div>
                <div class="form-group my-4">
                    <label for="image_name">Image name</label>
                    <input type="text" class="form-control" id="image_name" aria-describedby="Image name" placeholder="Enter image name: imgname.png">
                </div>
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
    <div class="my-4 remove" style='display:none'>
        <div class="row justify-content-center">
            <form class="col-11 col-md-9 form-remove" action='remove-manager' method='POST'>
                <input type='hidden' value='members'>
                <button type="submit" class="btn btn-primary my-4">Submit</button>
            </form>
        </div>
    </div>
    <script>
        parseElements("<%- content %>");
    </script>
<%- include('partials/footer.ejs') %>